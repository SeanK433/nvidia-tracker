{
  "name": "nvidia-tracker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "wrangler dev",
    "deploy": "astro build && node -e \"require('fs').writeFileSync('dist/.assetsignore', '_worker.js\\n')\" && wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "collect": "tsx scripts/collect.ts",
    "remind": "tsx scripts/send-reminder.ts",
    "validate-data": "tsx scripts/validate-data.ts"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^11.0.0",
    "astro": "^4.16.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "cheerio": "^1.0.0",
    "resend": "^3.5.0",
    "rss-parser": "^3.13.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "wrangler": "^3.78.0"
  }
}
