---
// src/components/Graph.astro
// Renders a Cytoscape force-directed graph of NVIDIA partnerships.
// Client-hydrated; SSR renders an empty container.
import { existsSync, readFileSync } from 'node:fs';
import { resolve } from 'node:path';
import { loadRelationships } from '~/lib/data';

function partnerHasLogo(id: string): boolean {
  return existsSync(resolve(process.cwd(), 'public', 'logos', `${id}.svg`));
}

function getLogoAspect(id: string): number {
  const path = resolve(process.cwd(), 'public', 'logos', `${id}.svg`);
  if (!existsSync(path)) return 1.85;
  try {
    const svg = readFileSync(path, 'utf-8').slice(0, 2000);
    const m = svg.match(/viewBox=['"]([\d.\s,-]+)['"]/);
    if (m) {
      const parts = m[1].trim().split(/[\s,]+/).map(Number);
      const w = parts[2];
      const h = parts[3];
      if (w > 0 && h > 0) return w / h;
    }
  } catch {}
  return 1.85;
}

const relationships = loadRelationships().filter((r) => r.status === 'active');

const CATEGORIES = ['silicon', 'interconnect', 'cloud', 'software', 'vertical', 'investment'] as const;

// Build the elements:
// - 1 NVIDIA center node
// - 6 category-label nodes (one per category)
// - 28 partner nodes (no kind change)
// - 6 trunk edges (NVIDIA -> each category label)
const elements = [
  { data: { id: 'nvidia', kind: 'center', label: 'NVIDIA', logo: '/logos/nvidia.svg' } },
  ...CATEGORIES.map((c) => ({
    data: {
      id: `label-${c}`,
      kind: 'category-label',
      label: c.charAt(0).toUpperCase() + c.slice(1)
    }
  })),
  ...relationships.map((r) => ({
    data: {
      id: r.id,
      label: r.partner,
      kind: 'partner',
      category: r.category,
      confidence: r.confidence,
      evidenceCount: Math.max(1, r.evidence_history.length),
      logo: `/logos/${r.id}.svg`,
      hasLogo: partnerHasLogo(r.id),
      logoAspect: getLogoAspect(r.id),
      partner: r.partner,
      purpose: r.purpose,
      lastConfirmed: r.last_confirmed
    }
  })),
  ...CATEGORIES.map((c) => ({
    data: { id: `e-trunk-${c}`, source: 'nvidia', target: `label-${c}` }
  }))
];

const elementsJson = JSON.stringify(elements);
---
<div id="graph-container" class="graph-container" data-elements={elementsJson}></div>

<style>
.graph-container {
  width: 100%;
  height: 100vh;
  min-height: 480px;
  position: relative;
  background: transparent;
}
</style>

<script>
// Mobile fallback: redirect to /list if the viewport is too narrow for the graph.
// Use a coarse-pointer media query to also catch tablets/touch devices.
const isMobile = window.matchMedia('(max-width: 768px), (pointer: coarse)').matches;
if (isMobile) {
  window.location.replace('/list');
  // Still load cytoscape below for desktop-resize edge cases — the redirect happens before paint.
}

import cytoscape from 'cytoscape';
// @ts-expect-error - cose-bilkent has no bundled types
import coseBilkent from 'cytoscape-cose-bilkent';

cytoscape.use(coseBilkent);

const container = document.getElementById('graph-container');
const hoverCard = document.getElementById('hover-card');
const hoverLogo = document.getElementById('hover-card-logo') as HTMLImageElement | null;
const hoverName = document.getElementById('hover-card-name');
const hoverMeta = document.getElementById('hover-card-meta');
const hoverPurpose = document.getElementById('hover-card-purpose');

if (container && hoverCard && hoverLogo && hoverName && hoverMeta && hoverPurpose) {
  const elements = JSON.parse(container.dataset.elements ?? '[]');

  const CATEGORIES = ['silicon', 'interconnect', 'cloud', 'software', 'vertical', 'investment'] as const;

  function computePositions(allElements: typeof elements, w: number, h: number) {
    const positions: Record<string, { x: number; y: number }> = {};

    const cx = w / 2;
    const cy_ = h * 0.56;
    positions.nvidia = { x: cx, y: cy_ };

    // 3 column x-positions across the canvas
    const COL_X = [w * 0.18, w * 0.50, w * 0.82];

    // Label y-offsets: 100px above/below NVIDIA
    const LABEL_OFFSET = 100;
    const LOGO_SPACING = 36;
    const SUB_COL_SPACING = 120; // horizontal gap between sub-columns within one cluster
    const MAX_ROWS = 4;

    // Mapping: which row (top/bottom) and column (0/1/2) each category lives in
    const CLUSTER_LAYOUT: Record<string, { row: 'top' | 'bottom'; col: 0 | 1 | 2 }> = {
      silicon:      { row: 'top',    col: 0 },
      interconnect: { row: 'top',    col: 1 },
      cloud:        { row: 'top',    col: 2 },
      software:     { row: 'bottom', col: 0 },
      vertical:     { row: 'bottom', col: 1 },
      investment:   { row: 'bottom', col: 2 }
    };

    // Group partners by category
    const partners = allElements.filter((e: { data?: { kind?: string } }) => e.data?.kind === 'partner');
    const grouped: Record<string, typeof partners> = {};
    for (const p of partners) {
      const cat = p.data.category;
      (grouped[cat] ??= []).push(p);
    }

    // Position each cluster
    for (const [cat, layout] of Object.entries(CLUSTER_LAYOUT)) {
      const clusterX = COL_X[layout.col];
      const extendDir = layout.row === 'top' ? -1 : 1; // -1 = up, +1 = down
      const labelY = cy_ + extendDir * LABEL_OFFSET;
      positions[`label-${cat}`] = { x: clusterX, y: labelY };

      // Balance partners into K columns: K=1 for n<=1, K=2 for n in [2..8],
      // K=3 for n>=9. rowsPerCol = floor(n/K). Any leftover (0, 1, or 2)
      // are orphans placed one row past the bulk on the outer side
      // (away from NVIDIA). 1 orphan: centered at clusterX. 2 orphans:
      // straddle clusterX at ±SUB_COL_SPACING/2.
      const items = grouped[cat] ?? [];
      const n = items.length;
      const numSubCols = n <= 1 ? 1 : n <= 8 ? 2 : 3;
      const rowsPerCol = Math.floor(n / numSubCols);
      const bulkCount = numSubCols * rowsPerCol;
      const numOrphans = n - bulkCount;
      const orphanRowY = labelY + extendDir * (rowsPerCol + 1) * LOGO_SPACING;

      items.forEach((p: { data: { id: string } }, i: number) => {
        if (i < bulkCount) {
          const subColIdx = Math.floor(i / rowsPerCol);
          const rowIdx = i % rowsPerCol;
          const subColXOffset = (subColIdx - (numSubCols - 1) / 2) * SUB_COL_SPACING;
          const partnerY = labelY + extendDir * (rowIdx + 1) * LOGO_SPACING;
          positions[p.data.id] = {
            x: clusterX + subColXOffset,
            y: partnerY
          };
        } else {
          const orphanIdx = i - bulkCount;
          const orphanXOffset = numOrphans === 2
            ? (orphanIdx === 0 ? -SUB_COL_SPACING / 2 : SUB_COL_SPACING / 2)
            : 0;
          positions[p.data.id] = {
            x: clusterX + orphanXOffset,
            y: orphanRowY
          };
        }
      });
    }

    return positions;
  }

  const w = container.clientWidth;
  const h = container.clientHeight;
  const positions = computePositions(elements, w, h);

  // Inject positions into elements
  const positionedElements = elements.map((e: { data?: { id?: string } }) => {
    if (e.data?.id && positions[e.data.id]) {
      return { ...e, position: positions[e.data.id] };
    }
    return e;
  });

  const cy = cytoscape({
    container,
    elements: positionedElements,
    layout: { name: 'preset', fit: false },
    zoom: 1,
    pan: { x: 0, y: 0 },
    userZoomingEnabled: false,
    userPanningEnabled: false,
    boxSelectionEnabled: false,
    autoungrabify: true,
    minZoom: 0.4,
    maxZoom: 2.5,
    style: [
      {
        selector: 'node[kind="center"]',
        style: {
          'shape': 'ellipse',
          'background-color': '#1a1612',
          'background-opacity': 1,
          'width': 130,
          'height': 130,
          'border-width': 0
        }
      },
      {
        selector: 'node[kind="anchor"]',
        style: {
          'width': 1,
          'height': 1,
          'background-opacity': 0,
          'border-width': 0,
          'label': '',
          'events': 'no'
        }
      },
      {
        selector: 'node[kind="category-label"]',
        style: {
          'shape': 'rectangle',
          'background-color': '#f3ede0',
          'background-opacity': 1,
          'border-width': 0,
          'label': 'data(label)',
          'color': '#1a1612',
          'font-family': 'Georgia, serif',
          'font-style': 'italic',
          'font-size': 12,
          'font-weight': 400,
          'text-valign': 'center',
          'text-halign': 'center',
          'width': 'label',
          'height': 'label',
          'padding': '8px',
          'events': 'no'
        }
      },
      {
        // Partners WITH a logo: the node itself is invisible/transparent. The actual
        // logo is rendered as an HTML <img> overlay positioned via the cy:viewport
        // event handler at the bottom of this script.
        selector: 'node[kind="partner"][?hasLogo]',
        style: {
          'shape': 'rectangle',
          'background-opacity': 0,
          'border-width': 0,
          'label': '',
          'width': (ele: cytoscape.NodeSingular) => {
            const baseHeight = 18 + Math.min(ele.data('evidenceCount'), 10) * 2;
            const aspect = ele.data('logoAspect') ?? 1.85;
            return Math.min(100, Math.max(28, baseHeight * aspect));
          },
          'height': (ele: cytoscape.NodeSingular) => 18 + Math.min(ele.data('evidenceCount'), 10) * 2
        }
      },
      {
        // Partners WITHOUT a sourced SVG logo: render the partner name as italic serif text.
        selector: 'node[kind="partner"][!hasLogo]',
        style: {
          'shape': 'rectangle',
          'background-opacity': 0,
          'border-width': 0,
          'label': 'data(partner)',
          'color': '#1a1612',
          'font-family': 'Georgia, serif',
          'font-style': 'italic',
          'font-size': 10,
          'font-weight': 500,
          'text-valign': 'center',
          'text-halign': 'center',
          'text-opacity': 1,
          'width': 'label',
          'height': 'label',
          'padding': '8px'
        }
      },
      {
        selector: 'edge',
        style: {
          'curve-style': 'straight',
          'line-color': '#1a1612',
          'line-opacity': 0.7,
          'width': 1.6,
          'target-arrow-shape': 'none',
          'source-arrow-shape': 'none'
        }
      },
      {
        selector: '.filtered-out',
        style: { 'opacity': 0.06, 'text-opacity': 0 }
      },
      {
        selector: '.dimmed',
        style: { 'opacity': 0.18 }
      },
      {
        selector: '.highlighted',
        style: { 'opacity': 1 }
      }
    ]
  });

  cy.on('mouseover', 'node[kind="partner"]', (evt) => {
    const node = evt.target;
    // Dim only OTHER partners. Trunk edges, category labels, and the NVIDIA
    // center stay at their natural opacity so the cluster scaffolding doesn't
    // flicker while cycling between partners.
    cy.nodes('node[kind="partner"]').addClass('dimmed');
    node.removeClass('dimmed').addClass('highlighted');

    const data = node.data();
    hoverLogo.src = data.logo;
    hoverLogo.alt = data.partner;
    hoverName.textContent = data.partner;
    hoverMeta.textContent = `${data.category} · ${data.evidenceCount} confirmation${data.evidenceCount === 1 ? '' : 's'}`;
    hoverPurpose.textContent = data.purpose;

    // Position the card so it doesn't open off-screen.
    // Right third of canvas: open LEFT (card sits to the left of cursor).
    // Bottom half of canvas: open UP (card's bottom anchors near cursor).
    // Otherwise: open RIGHT and DOWN (default).
    const renderedPos = node.renderedPosition();
    const containerRect = container.getBoundingClientRect();
    const cw = container.clientWidth;
    const ch = container.clientHeight;
    const cardW = hoverCard.offsetWidth;
    const cardH = hoverCard.offsetHeight;
    const openLeft = renderedPos.x > cw * (2 / 3);
    const openUp = renderedPos.y > ch * 0.5;
    const offsetX = 30;
    const offsetY = 20;
    hoverCard.style.left = openLeft
      ? `${containerRect.left + renderedPos.x - cardW - offsetX}px`
      : `${containerRect.left + renderedPos.x + offsetX}px`;
    hoverCard.style.top = openUp
      ? `${containerRect.top + renderedPos.y - cardH + offsetY}px`
      : `${containerRect.top + renderedPos.y - offsetY}px`;
    hoverCard.dataset.visible = 'true';
  });

  cy.on('mouseout', 'node[kind="partner"]', () => {
    cy.elements().removeClass('dimmed').removeClass('highlighted');
    hoverCard.dataset.visible = 'false';
  });

  cy.on('tap', 'node[kind="partner"]', (evt) => {
    const id = evt.target.data('id');
    window.location.href = `/partners/${id}`;
  });

  document.addEventListener('graph:filter', (e) => {
    const detail = (e as CustomEvent<{ category: string }>).detail;
    const cat = detail.category;
    if (cat === 'all') {
      cy.nodes('node[kind="partner"]').removeClass('filtered-out');
      return;
    }
    cy.nodes('node[kind="partner"]').forEach((n) => {
      if (n.data('category') === cat) {
        n.removeClass('filtered-out');
      } else {
        n.addClass('filtered-out');
      }
    });
  });

  // ============================================================
  // HTML <img> overlay layer for partner logos.
  // Cytoscape's background-fit:contain misbehaves on SVGs with
  // intrinsic dimensions or preserveAspectRatio attrs (Oracle,
  // CoreWeave, Adobe, Microsoft, Schneider all clipped). We render
  // logos as absolutely-positioned <img> elements over the canvas
  // and update positions on every Cytoscape viewport/render event.
  // ============================================================
  const overlayLayer = document.createElement('div');
  overlayLayer.id = 'partner-logo-overlays';
  overlayLayer.style.cssText = [
    'position: absolute',
    'inset: 0',
    'pointer-events: none',
    'overflow: hidden',
    'z-index: 5'
  ].join(';');
  container.appendChild(overlayLayer);

  const overlayElements: Record<string, HTMLImageElement> = {};

  // Build one <img> per partner-with-logo. They're hidden (display:none) until first position.
  cy.nodes('node[kind="partner"][?hasLogo]').forEach((node) => {
    const img = document.createElement('img');
    img.src = node.data('logo');
    img.alt = node.data('partner');
    img.style.cssText = [
      'position: absolute',
      'object-fit: contain',
      'object-position: center',
      'pointer-events: none',
      'transition: opacity 0.15s'
    ].join(';');
    img.dataset.partner = node.data('partner');
    overlayLayer.appendChild(img);
    overlayElements[node.id()] = img;
  });

  // NVIDIA center node: also render logo as an HTML <img> overlay (same approach as partners).
  // Cytoscape's canvas background-image for SVGs is unreliable on first paint.
  const nvOverlay = document.createElement('img');
  nvOverlay.src = '/logos/nvidia.svg';
  nvOverlay.alt = 'NVIDIA';
  nvOverlay.style.cssText = [
    'position: absolute',
    'object-fit: contain',
    'object-position: center',
    'pointer-events: none'
  ].join(';');
  overlayLayer.appendChild(nvOverlay);

  function updateOverlayPositions() {
    const zoom = cy.zoom();
    cy.nodes('node[kind="partner"][?hasLogo]').forEach((node) => {
      const img = overlayElements[node.id()];
      if (!img) return;
      const pos = node.renderedPosition();
      const w = node.width() * zoom;
      const h = node.height() * zoom;
      img.style.left = (pos.x - w / 2) + 'px';
      img.style.top = (pos.y - h / 2) + 'px';
      img.style.width = w + 'px';
      img.style.height = h + 'px';
      // Sync filter-out dimming
      img.style.opacity = node.hasClass('filtered-out') ? '0.06' : '1';
    });

    // Position NVIDIA center overlay: 70% of node diameter, centered
    const nvNode = cy.getElementById('nvidia');
    if (nvNode) {
      const pos = nvNode.renderedPosition();
      const nodeDiam = nvNode.width() * zoom;   // 130 * zoom
      const logoW = nodeDiam * 0.70;            // 70% of circle diameter
      const logoH = logoW * (30 / 164);         // maintain 164:30 SVG aspect
      nvOverlay.style.left = (pos.x - logoW / 2) + 'px';
      nvOverlay.style.top  = (pos.y - logoH / 2) + 'px';
      nvOverlay.style.width  = logoW + 'px';
      nvOverlay.style.height = logoH + 'px';
    }
  }

  // Initial paint
  updateOverlayPositions();
  // Re-render on any change that affects node positions or visibility
  cy.on('render viewport pan zoom position', updateOverlayPositions);
  // Also refresh when filter-out classes change (custom listener since class events aren't standard)
  document.addEventListener('graph:filter', () => {
    // Run on next tick after the existing filter listener runs
    setTimeout(updateOverlayPositions, 0);
  });

  (window as unknown as { cy?: cytoscape.Core }).cy = cy;
}
</script>
